# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# Database
DATABASE_URL=sqlite:///sec2systems.db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# Email Configuration (Gmail Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@sec2systems.com

# Application Settings
INSTITUTE_NAME=SEC2SYSTEMS
INSTITUTE_EMAIL=info@sec2systems.com
INSTITUTE_PHONE=+91 8179066637

# CORS Settings
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5000
